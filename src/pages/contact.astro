---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---

<BaseLayout
  title="Contact"
  description="Subscribe to the Doctors Who Code newsletter or connect with Dr. Chukwuma Onyeije on LinkedIn."
>
  <div style="max-width: 700px; margin: 0 auto; padding: 3rem 1.5rem 5rem;">

    <div style="margin-bottom: 3rem;">
      <p class="label" style="margin-bottom: 0.75rem;">Get in Touch</p>
      <h1 style="font-size: 2.25rem; margin-bottom: 0.75rem;">Contact</h1>
      <p style="font-size: 1.0625rem; color: var(--dwc-muted); line-height: 1.7;">
        The best way to reach me is LinkedIn. For general inquiries, speaking requests, or
        collaboration on physician-developer projects, connect there directly.
      </p>
    </div>

    <!-- Newsletter -->
    <div style="margin-bottom: 3rem;">
      <NewsletterForm />
    </div>

    <!-- LinkedIn CTA -->
    <div style="background-color: var(--dwc-card); border: 1px solid var(--dwc-border); border-radius: 12px; padding: 1.75rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
      <div>
        <p class="label" style="margin-bottom: 0.375rem;">Connect on LinkedIn</p>
        <p style="font-size: 0.9375rem; color: var(--dwc-muted); margin: 0;">
          Chukwuma Onyeije, MD, FACOG
        </p>
      </div>
      <a
        href="https://linkedin.com/in/chukwumaonyeije"
        target="_blank"
        rel="noopener noreferrer"
        style="font-family: var(--font-mono); font-size: 0.875rem; color: var(--dwc-navy); background-color: var(--dwc-cyan); padding: 0.5rem 1.25rem; border-radius: 6px; white-space: nowrap;"
      >
        LinkedIn &rarr;
      </a>
    </div>

  </div>
</BaseLayout>
