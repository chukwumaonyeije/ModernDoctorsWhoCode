---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content, headings } = await render(post);

// Use hero image if set, otherwise fall back to the generated OG card
const ogImage = post.data.image?.url ?? `/og/${post.id}.png`;

// Auto reading time: strip MDX/markdown syntax, count words, assume 200 wpm
const wordCount = (post.body ?? '')
  .replace(/```[\s\S]*?```/g, '')   // remove code blocks
  .replace(/`[^`]*`/g, '')          // remove inline code
  .replace(/!\[.*?\]\(.*?\)/g, '')  // remove images
  .replace(/\[.*?\]\(.*?\)/g, '$1') // remove link syntax
  .replace(/<[^>]+>/g, '')          // remove HTML tags
  .replace(/[#*_~>\-|]/g, '')       // remove markdown symbols
  .trim()
  .split(/\s+/)
  .filter(Boolean)
  .length;
const readingTime = post.data.readingTime ?? Math.max(1, Math.ceil(wordCount / 200));
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  author={post.data.author}
  authorUrl={post.data.authorUrl}
  tags={post.data.tags}
  category={post.data.category}
  image={post.data.image}
  ogImage={ogImage}
  readingTime={readingTime}
  canonical={post.data.canonical}
  headings={headings}
>
  <Content />
</PostLayout>
