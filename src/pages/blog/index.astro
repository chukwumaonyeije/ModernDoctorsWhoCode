---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Collect tags used by 3+ posts only
const tagCounts = sortedPosts.flatMap(p => p.data.tags).reduce((acc, tag) => {
  acc[tag] = (acc[tag] ?? 0) + 1;
  return acc;
}, {} as Record<string, number>);
const allTags = Object.entries(tagCounts)
  .filter(([, count]) => count >= 3)
  .sort((a, b) => b[1] - a[1])
  .map(([tag]) => tag);
---

<BaseLayout
  title="Blog"
  description="Physician-developer insights on AI in medicine, clinical software, MFM practice, and building tools that actually work."
>
  <div style="max-width: 1200px; margin: 0 auto; padding: 3rem 1.5rem 5rem;">

    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: flex-end; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 2rem;">
      <div>
        <p class="label" style="margin-bottom: 0.5rem;">All Posts</p>
        <h1 class="gradient-text" style="font-size: 2.5rem; margin: 0;">The Blog</h1>
      </div>
      <input
        type="search"
        id="post-search"
        placeholder="Search posts..."
        style="background-color: var(--dwc-card); border: 1px solid var(--dwc-border); border-radius: 8px; padding: 0.625rem 1rem; color: var(--dwc-white); font-family: var(--font-mono); font-size: 0.875rem; width: 260px; outline: none;"
      />
    </div>

    <!-- Tag filter — single scrollable row -->
    <div style="overflow-x: auto; padding-bottom: 0.5rem; margin-bottom: 2rem;">
      <div style="display: flex; gap: 0.5rem; min-width: max-content;" id="tag-filters">
        <button class="tag-btn active" data-tag="all"
          style="font-family: var(--font-mono); font-size: 0.7rem; padding: 0.3rem 0.75rem; border-radius: 4px; border: 1px solid var(--dwc-cyan); color: var(--dwc-navy); background-color: var(--dwc-cyan); cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap;"
        >All</button>
        {allTags.map(tag => (
          <button class="tag-btn" data-tag={tag}
            style="font-family: var(--font-mono); font-size: 0.7rem; padding: 0.3rem 0.75rem; border-radius: 4px; border: 1px solid var(--dwc-border); color: var(--dwc-muted); background-color: transparent; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap;"
          >{tag}</button>
        ))}
      </div>
    </div>

    <!-- Posts grid -->
    <div id="posts-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
      {sortedPosts.map(post => (
        <div class="post-item" data-tags={post.data.tags.join(',')} data-title={post.data.title.toLowerCase()} data-description={post.data.description.toLowerCase()}>
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
            category={post.data.category}
            readingTime={post.data.readingTime}
            image={post.data.image}
            featured={post.data.featured}
          />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="no-results" style="display: none; text-align: center; padding: 4rem 0;">
      <p style="color: var(--dwc-muted); font-family: var(--font-mono);">No posts match that filter.</p>
    </div>

  </div>
</BaseLayout>

<script>
  const tagBtns = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const postItems = document.querySelectorAll<HTMLElement>('.post-item');
  const searchInput = document.getElementById('post-search') as HTMLInputElement;
  const noResults = document.getElementById('no-results')!;

  let activeTag = 'all';
  let searchQuery = '';

  function filterPosts() {
    let visible = 0;
    postItems.forEach(item => {
      const tags = item.dataset.tags ?? '';
      const title = item.dataset.title ?? '';
      const desc = item.dataset.description ?? '';
      const matchesTag = activeTag === 'all' || tags.split(',').includes(activeTag);
      const matchesSearch = !searchQuery || title.includes(searchQuery) || desc.includes(searchQuery);
      if (matchesTag && matchesSearch) {
        item.style.display = '';
        visible++;
      } else {
        item.style.display = 'none';
      }
    });
    noResults.style.display = visible === 0 ? 'block' : 'none';
  }

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeTag = btn.dataset.tag ?? 'all';
      tagBtns.forEach(b => {
        b.style.borderColor = 'var(--dwc-border)';
        b.style.color = 'var(--dwc-muted)';
        b.style.backgroundColor = 'transparent';
      });
      btn.style.borderColor = 'var(--dwc-cyan)';
      btn.style.color = 'var(--dwc-navy)';
      btn.style.backgroundColor = 'var(--dwc-cyan)';
      filterPosts();
    });
  });

  searchInput.addEventListener('input', () => {
    searchQuery = searchInput.value.toLowerCase().trim();
    filterPosts();
  });
</script>
