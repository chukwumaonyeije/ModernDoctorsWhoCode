---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="Chukwuma Onyeije, MD, FACOG is a Maternal-Fetal Medicine specialist, physician-developer, and founder of CodeCraftMD and OpenMFM.org."
>
  <div style="max-width: 900px; margin: 0 auto; padding: 3rem 1.5rem 5rem;">

    <!-- Header -->
    <div style="margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid var(--dwc-border);">
      <p class="label" style="margin-bottom: 0.75rem;">About the Author</p>
      <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">Chukwuma Onyeije, MD, FACOG</h1>
      <p style="font-family: var(--font-mono); font-size: 0.875rem; color: var(--dwc-cyan);">
        Maternal-Fetal Medicine Specialist &middot; Physician-Developer &middot; Atlanta, GA
      </p>
    </div>

    <!-- Bio -->
    <div style="margin-bottom: 3rem;">
      <p style="font-size: 1.0625rem; line-height: 1.8; margin-bottom: 1.25rem;">
        I am a Maternal-Fetal Medicine (MFM) specialist at Atlanta Perinatal Associates in Atlanta, Georgia.
        I manage high-risk pregnancies: fetal anomalies, preterm birth, preeclampsia, diabetes in pregnancy,
        and complex maternal conditions. That is my clinical life.
      </p>
      <p style="font-size: 1.0625rem; line-height: 1.8; margin-bottom: 1.25rem;">
        My other life is building software. I write Python, TypeScript, and whatever else the problem
        requires. I build AI tools for physicians because I believe doctors with domain expertise can
        build better healthcare technology than any external vendor. That belief is the foundation of
        everything on this blog.
      </p>
      <p style="font-size: 1.0625rem; line-height: 1.8;">
        I am also a Seventh-day Adventist elder, a theologian, and an endurance athlete managing
        type 2 diabetes through the Mastering Diabetes protocol. The same systems thinking I apply
        in the clinic, I apply to training and to software.
      </p>
    </div>

    <!-- Credentials -->
    <div style="margin-bottom: 3rem;">
      <p class="label" style="margin-bottom: 1rem;">Credentials</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1rem;">
        {[
          { label: 'Degree', value: 'MD' },
          { label: 'Certification', value: 'FACOG' },
          { label: 'Board Certified', value: 'Maternal-Fetal Medicine' },
          { label: 'Practice', value: 'Atlanta Perinatal Associates' },
          { label: 'Location', value: 'Atlanta, GA' },
          { label: 'Specialty', value: 'High-Risk Obstetrics / MFM' },
        ].map(item => (
          <div style="background-color: var(--dwc-card); border: 1px solid var(--dwc-border); border-radius: 8px; padding: 1rem;">
            <p class="label" style="font-size: 0.65rem; margin-bottom: 0.25rem;">{item.label}</p>
            <p style="font-size: 0.9375rem; font-weight: 600; margin: 0; color: var(--dwc-white);">{item.value}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Projects -->
    <div style="margin-bottom: 3rem;">
      <p class="label" style="margin-bottom: 1rem;">Projects</p>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        {[
          {
            name: 'CodeCraftMD',
            url: 'https://codecraftmd.com',
            description: 'AI-powered medical documentation and billing platform. Python backend with ICD-10/CPT extraction. HIPAA-compliant architecture.',
          },
          {
            name: 'OpenMFM.org',
            url: 'https://openmfm.org',
            description: 'Open-source clinical knowledge platform for MFM education. Built for MFM fellows, OB residents, and practicing MFMs.',
          },
          {
            name: 'Doctors Who Code',
            url: '/blog',
            description: 'This blog. A record of building physician-owned AI tools and an argument for why physicians should write the software they use.',
          },
        ].map(project => (
          <div style="background-color: var(--dwc-card); border: 1px solid var(--dwc-border); border-radius: 12px; padding: 1.5rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
              <h3 style="font-size: 1.125rem; margin: 0;">{project.name}</h3>
              <a href={project.url} target={project.url.startsWith('http') ? '_blank' : '_self'} rel="noopener noreferrer" style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--dwc-cyan);">Visit &rarr;</a>
            </div>
            <p style="font-size: 0.9375rem; color: var(--dwc-muted); margin: 0; line-height: 1.6;">{project.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Connect -->
    <div>
      <p class="label" style="margin-bottom: 1rem;">Connect</p>
      <div style="display: flex; flex-wrap: wrap; gap: 1rem;">
        <a href="https://linkedin.com/in/chukwumaonyeije" target="_blank" rel="noopener noreferrer" style="font-family: var(--font-mono); font-size: 0.875rem; color: var(--dwc-cyan); background-color: var(--dwc-card); border: 1px solid var(--dwc-border); padding: 0.5rem 1rem; border-radius: 6px;">LinkedIn</a>
        <a href="https://x.com/chukwumaonyeije" target="_blank" rel="noopener noreferrer" style="font-family: var(--font-mono); font-size: 0.875rem; color: var(--dwc-cyan); background-color: var(--dwc-card); border: 1px solid var(--dwc-border); padding: 0.5rem 1rem; border-radius: 6px;">X / Twitter</a>
        <a href="https://x.com/CodeCraftMD" target="_blank" rel="noopener noreferrer" style="font-family: var(--font-mono); font-size: 0.875rem; color: var(--dwc-cyan); background-color: var(--dwc-card); border: 1px solid var(--dwc-border); padding: 0.5rem 1rem; border-radius: 6px;">CodeCraftMD on X</a>
      </div>
    </div>

  </div>
</BaseLayout>
