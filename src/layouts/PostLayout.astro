---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import AuthorBio from '../components/AuthorBio.astro';
import FormattedDate from '../components/FormattedDate.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import PostCard from '../components/PostCard.astro';
import AudioPlayer from '../components/AudioPlayer.astro';
import { SITE_URL, AUTHOR_NAME, AUTHOR_URL, SITE_TITLE } from '../consts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  authorUrl?: string;
  tags?: string[];
  category?: string;
  image?: { url: string; alt: string };
  ogImage?: string;
  readingTime?: number;
  canonical?: string;
  headings?: { depth: number; slug: string; text: string }[];
  audioUrl?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author = AUTHOR_NAME,
  authorUrl = AUTHOR_URL,
  tags = [],
  category = 'Technology',
  image,
  ogImage = image?.url ?? '/images/og-default.jpg',
  readingTime,
  canonical = Astro.url.href,
  headings = [],
  audioUrl,
} = Astro.props;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Person",
    "name": author,
    "url": authorUrl,
    "jobTitle": "Maternal-Fetal Medicine Specialist",
    "worksFor": {
      "@type": "Organization",
      "name": "Atlanta Perinatal Associates"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": SITE_TITLE,
    "url": SITE_URL
  },
  "datePublished": pubDate.toISOString(),
  "dateModified": (updatedDate ?? pubDate).toISOString(),
  "image": ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`,
  "url": canonical,
};

// Only show TOC if there are headings at depth 2 or 3
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

// Related posts: match by shared tags, exclude current post
const currentSlug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter(p => p.id !== currentSlug && p.data.tags?.some(t => tags.includes(t)))
  .sort((a, b) => {
    const sharedA = a.data.tags.filter(t => tags.includes(t)).length;
    const sharedB = b.data.tags.filter(t => tags.includes(t)).length;
    return sharedB - sharedA || b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 3);
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogType="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
  articleSchema={articleSchema}
>
  <div style="max-width: 1200px; margin: 0 auto; padding: 3rem 1.5rem; display: grid; grid-template-columns: 1fr 280px; gap: 4rem; align-items: start;">

    <!-- Main post content -->
    <article>
      <!-- Category + reading time -->
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.25rem;">
        <span class="label">{category}</span>
        {readingTime && (
          <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--dwc-muted);">{readingTime} min read</span>
        )}
      </div>

      <!-- Title -->
      <h1 class="gradient-text" style="font-size: 2.5rem; margin-bottom: 1rem;">{title}</h1>

      <!-- Description -->
      <p style="font-size: 1.125rem; color: var(--dwc-muted); margin-bottom: 1.5rem; line-height: 1.6;">{description}</p>

      <!-- Enhanced author block -->
      <div style="padding: 1.25rem 1.5rem; background: var(--dwc-card); border: 1px solid var(--dwc-border); border-left: 3px solid; border-image: linear-gradient(to bottom, #a855f7, #38bdf8) 1; border-radius: 0 8px 8px 0; margin-bottom: 2rem;">
        <p style="font-size: 0.9375rem; font-weight: 600; color: var(--dwc-white); margin: 0 0 0.25rem 0;">
          By Dr. Chukwuma Onyeije, MD, FACOG
        </p>
        <p style="font-size: 0.8125rem; color: var(--dwc-muted); margin: 0 0 0.5rem 0;">
          Maternal-Fetal Medicine Specialist &amp; Medical Director, Atlanta Perinatal Associates
        </p>
        <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--dwc-muted); margin: 0; display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
          <span>Founder, Doctors Who Code &middot; OpenMFM.org &middot; CodeCraftMD</span>
          <span style="color: var(--dwc-border);">&middot;</span>
          <span><FormattedDate date={pubDate} /></span>
          {readingTime && (
            <>
              <span style="color: var(--dwc-border);">&middot;</span>
              <span>{readingTime} min read</span>
            </>
          )}
        </p>
      </div>

      <!-- Audio player -->
      {audioUrl && <AudioPlayer src={audioUrl} title={title} />}

      <!-- Featured image -->
      {image && (
        <img
          src={image.url}
          alt={image.alt}
          style="width: 100%; border-radius: 12px; margin-bottom: 2rem; border: 1px solid var(--dwc-border);"
        />
      )}

      <!-- Post body -->
      <div class="prose">
        <slot />
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--dwc-border);">
          {tags.map(tag => (
            <a
              href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
              class="tag-pill"
            >
              {tag}
            </a>
          ))}
        </div>
      )}

      <!-- Share links -->
      <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--dwc-border);">
        <span class="label">Share</span>
        <a
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(canonical)}`}
          target="_blank"
          rel="noopener noreferrer"
          style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--dwc-muted); text-decoration: none; padding: 0.375rem 0.75rem; border: 1px solid var(--dwc-border); border-radius: 6px; transition: color 0.2s, border-color 0.2s;"
        >X / Twitter</a>
        <a
          href={`https://bsky.app/intent/compose?text=${encodeURIComponent(title + ' ' + canonical)}`}
          target="_blank"
          rel="noopener noreferrer"
          style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--dwc-muted); text-decoration: none; padding: 0.375rem 0.75rem; border: 1px solid var(--dwc-border); border-radius: 6px; transition: color 0.2s, border-color 0.2s;"
        >Bluesky</a>
        <a
          href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonical)}`}
          target="_blank"
          rel="noopener noreferrer"
          style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--dwc-muted); text-decoration: none; padding: 0.375rem 0.75rem; border: 1px solid var(--dwc-border); border-radius: 6px; transition: color 0.2s, border-color 0.2s;"
        >LinkedIn</a>
        <button
          id="copy-link-btn"
          data-url={canonical}
          style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--dwc-muted); background: none; border: 1px solid var(--dwc-border); border-radius: 6px; padding: 0.375rem 0.75rem; cursor: pointer; transition: color 0.2s, border-color 0.2s;"
        >Copy link</button>
      </div>

      <!-- Newsletter -->
      <div style="margin-top: 3rem;">
        <NewsletterForm
          title="Enjoyed this post?"
          subtitle="Get physician-developer insights delivered weekly. No hype. No filler."
        />
      </div>

      <!-- Related posts -->
      {relatedPosts.length > 0 && (
        <div style="margin-top: 3rem;">
          <p class="label" style="margin-bottom: 1.25rem;">Related Posts</p>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.25rem;">
            {relatedPosts.map(post => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                slug={post.id}
                tags={post.data.tags}
                category={post.data.category}
                readingTime={post.data.readingTime}
                image={post.data.image}
                featured={post.data.featured}
              />
            ))}
          </div>
        </div>
      )}

      <!-- Author bio -->
      <div style="margin-top: 3rem;">
        <AuthorBio />
      </div>
    </article>

    <!-- Sidebar TOC -->
    <aside style="position: sticky; top: 84px;">
      {tocHeadings.length > 0 && (
        <div style="background-color: var(--dwc-card); border: 1px solid var(--dwc-border); border-radius: 12px; padding: 1.5rem;">
          <p class="label" style="margin-bottom: 1rem;">On this page</p>
          <nav>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
              {tocHeadings.map(h => (
                <li style={h.depth === 3 ? 'padding-left: 1rem;' : ''}>
                  <a
                    href={`#${h.slug}`}
                    style="font-size: 0.875rem; color: var(--dwc-muted); line-height: 1.4; display: block; transition: color 0.2s;"
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      )}
    </aside>

  </div>
</BaseLayout>

<script>
  const btn = document.getElementById('copy-link-btn');
  btn?.addEventListener('click', async () => {
    const url = btn.getAttribute('data-url') ?? window.location.href;
    await navigator.clipboard.writeText(url);
    btn.textContent = 'Copied!';
    btn.style.color = 'var(--dwc-cyan)';
    btn.style.borderColor = 'var(--dwc-cyan)';
    setTimeout(() => {
      btn.textContent = 'Copy link';
      btn.style.color = '';
      btn.style.borderColor = '';
    }, 2000);
  });
</script>

<style>
  @media (max-width: 900px) {
    div[style*="grid-template-columns"] {
      grid-template-columns: 1fr !important;
    }
    aside {
      display: none;
    }
  }
</style>
