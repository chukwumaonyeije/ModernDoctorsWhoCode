---
// Replace BEEHIIV_EMBED_URL with your actual embed URL from the Beehiiv dashboard
const BEEHIIV_EMBED_URL = 'https://embeds.beehiiv.com/ae122d20-d362-4ced-ae4d-2f8ed8b5b273';
---

<div style="background-color: var(--dwc-card); border: 1px solid var(--dwc-border); border-radius: 12px; padding: 2rem; text-align: center;">
  <p class="label" style="margin-bottom: 0.5rem;">Newsletter</p>
  <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem;">Physicians who build, delivered weekly.</h3>
  <p style="font-size: 0.9375rem; color: var(--dwc-muted); margin-bottom: 1.5rem;">
    Clinical insights + developer tools for the physician-coder. No hype. No filler.
  </p>
  {BEEHIIV_EMBED_URL !== 'BEEHIIV_EMBED_URL' ? (
    <iframe
      src={BEEHIIV_EMBED_URL}
      width="100%"
      height="320"
      style="border: none; border-radius: 8px;"
      title="Newsletter signup"
    />
  ) : (
    <a
      href="/contact"
      style="display: inline-block; font-family: var(--font-mono); font-size: 0.875rem; color: var(--dwc-navy); background-color: var(--dwc-cyan); padding: 0.625rem 1.5rem; border-radius: 6px; font-weight: 500;"
    >
      Subscribe
    </a>
  )}
</div>
