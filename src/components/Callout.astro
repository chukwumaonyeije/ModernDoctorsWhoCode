---
interface Props {
  type: 'clinical' | 'technical' | 'warning' | 'note';
  title?: string;
}

const { type, title } = Astro.props;

const styles: Record<string, { border: string; label: string; bg: string }> = {
  clinical:  { border: '#2dd4bf', label: 'Clinical Note',  bg: 'rgba(45, 212, 191, 0.06)' },
  technical: { border: '#1a6fc4', label: 'Technical Note', bg: 'rgba(26, 111, 196, 0.06)' },
  warning:   { border: '#f59e0b', label: 'Warning',        bg: 'rgba(245, 158, 11, 0.06)' },
  note:      { border: '#94a3b8', label: 'Note',           bg: 'rgba(148, 163, 184, 0.06)' },
};

const s = styles[type];
---

<aside style={`border-left: 3px solid ${s.border}; background-color: ${s.bg}; border-radius: 0 8px 8px 0; padding: 1rem 1.25rem; margin: 1.75rem 0;`}>
  <p class="label" style={`color: ${s.border}; margin-bottom: 0.375rem;`}>
    {title ?? s.label}
  </p>
  <div style="font-size: 0.9375rem; color: var(--dwc-muted);">
    <slot />
  </div>
</aside>
