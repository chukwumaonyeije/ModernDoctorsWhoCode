---
import FormattedDate from './FormattedDate.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  category?: string;
  readingTime?: number;
  image?: { url: string; alt: string };
  featured?: boolean;
}

const {
  title,
  description,
  pubDate,
  slug,
  tags = [],
  category = 'Technology',
  readingTime,
  image,
  featured = false,
} = Astro.props;
---

<a href={`/blog/${slug}`} class="post-card-link" style="display: block; text-decoration: none;">
  <article class="card" style="padding: 1.5rem; height: 100%;">
    {image && (
      <img
        src={image.url}
        alt={image.alt}
        style="width: 100%; height: 180px; object-fit: cover; border-radius: 8px; margin-bottom: 1rem; border: 1px solid var(--dwc-border);"
      />
    )}

    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
      <span class="label">{category}</span>
      {featured && (
        <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--dwc-navy); background-color: var(--dwc-cyan); padding: 0.15rem 0.5rem; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.05em;">Featured</span>
      )}
    </div>

    <h3 style="font-size: 1.125rem; margin-bottom: 0.5rem; color: var(--dwc-white); line-height: 1.3;">{title}</h3>
    <p style="font-size: 0.875rem; color: var(--dwc-muted); margin-bottom: 1rem; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">{description}</p>

    <div style="display: flex; align-items: center; gap: 0.75rem; margin-top: auto;">
      <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--dwc-muted);">
        <FormattedDate date={pubDate} />
      </span>
      {readingTime && (
        <>
          <span style="color: var(--dwc-border);">&middot;</span>
          <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--dwc-muted);">{readingTime} min read</span>
        </>
      )}
    </div>

    {tags.length > 0 && (
      <div style="display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 1rem;">
        {tags.slice(0, 3).map(tag => (
          <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--dwc-muted); background-color: var(--dwc-navy); border: 1px solid var(--dwc-border); padding: 0.125rem 0.5rem; border-radius: 4px;">{tag}</span>
        ))}
      </div>
    )}
  </article>
</a>

<style>
  .post-card-link:hover article {
    transform: translateY(-2px);
    border-color: var(--dwc-blue);
  }
  article {
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
</style>
